# ── Cognee Cloud (the memory layer) ──────────────────────────────────────────
# Leave these unset to run in MOCK mode: a disk-backed store stands in for
# Cognee so the whole demo — including restart-persistence — works offline.
# Fill them in to go LIVE (the app auto-detects and flips the header badge).
#
# Base URL is your tenant host, e.g. https://your-tenant.aws.cognee.ai
COGNEE_BASE_URL=
COGNEE_API_KEY=

# ── LLM dialogue provider (any OpenAI-compatible endpoint) ────────────────────
# Cognee does NOT generate chat, so we need a separate LLM. Point at Groq /
# OpenRouter / Gemini's OpenAI layer / Ollama by swapping the base URL, key,
# and model. Leave unset to use built-in mock dialogue.
#   Groq:       https://api.groq.com/openai/v1   model: llama-3.1-8b-instant
#   OpenRouter: https://openrouter.ai/api/v1     model: meta-llama/llama-3.3-70b-instruct:free
#   Ollama:     http://localhost:11434/v1        model: llama3.2
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEYS=
LLM_MODEL=llama-3.1-8b-instant

# ── OpenRouter (legacy fallback; ignored while LLM_* above is set) ─────────────
OPENROUTER_API_KEYS=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
